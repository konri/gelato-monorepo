#!/bin/bash

# Kopiowanie pliku .env.dev do .env
cp .env.dev .env

# Usuwanie pliku prisma/.env, aby uniknąć konfliktów
rm -f prisma/.env

# Modyfikacja zmiennej DATABASE_URL, aby używała lokalnego portu 5433
sed -i '' 's/DATABASE_URL=.*/DATABASE_URL=postgres:\/\/p13675_easybons:EasyBons1!@localhost:5433\/p13675_easybons/g' .env
# Usunięcie DATABASE_URL_SHADOW (nie istnieje na serwerze produkcyjnym)
sed -i '' '/DATABASE_URL_SHADOW=/d' .env

echo "Uruchamianie tunelu SSH..."
# Uruchomienie tunelu SSH w tle
ssh -N -L 5433:pgsql5.mydevil.net:5432 kraczo@s5.mydevil.net &
TUNNEL_PID=$!

# Funkcja do zamknięcia tunelu SSH
cleanup() {
  echo "Zamykanie tunelu SSH (PID: $TUNNEL_PID)..."
  kill $TUNNEL_PID 2>/dev/null
}

# Przechwytywanie sygnałów zakończenia
trap cleanup EXIT SIGINT SIGTERM

# Czekanie na ustanowienie tunelu
sleep 3

echo "Usuwanie wszystkich tabel z bazy danych..."
# Połączenie z bazą i usunięcie wszystkich tabel
psql "postgres://p13675_easybons:EasyBons1!@localhost:5433/p13675_easybons" -c "
DROP SCHEMA public CASCADE;
CREATE SCHEMA public;
GRANT ALL ON SCHEMA public TO p13675_easybons;
GRANT ALL ON SCHEMA public TO public;
"

echo "Wszystkie tabele zostały usunięte."

# Tunel zostanie automatycznie zamknięty przez trap EXIT