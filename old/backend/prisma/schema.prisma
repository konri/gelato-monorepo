  imageUrl           String?
  couponType         CouponType?
  availability       AvailabilityType?
  displayType        VoucherDisplayType?
  pointsCost         Int?
  priority           Int?
  rewardId           String?
  validFrom          DateTime?
  validUntil         DateTime?
  maxUsesPerUser     Int?
  totalQuantity      Int?
  assignToUserId     String?
  exclusivityGroups  Json?
  buyQuantity        Int?
  getQuantity        Int?
  discountType       DiscountType?
  discountValue      Float?
  dayOfWeek          String?
  thresholdAmount    Float?
  discountAmount     Float?
  itemName           String?
  itemBarcode        String?
  daysBeforeBirthday Int?
  daysAfterBirthday  Int?
