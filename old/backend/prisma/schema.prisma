// Coupon System
enum CouponType {
  MULTI_BUY
  DISCOUNT
  DAY_OF_WEEK
  THRESHOLD_DISCOUNT
  ITEM_SPECIFIC
  BIRTHDAY
  ACTIVITY
}

enum AvailabilityType {
  FREE
  POINTS
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
}

model Coupon {
  id                 String             @id @default(uuid())
  code               String
  title              String
  description        String?
  shortDescription   String?
  termsAndConditions String?
  imageUrl           String?
  couponType         CouponType
  availability       AvailabilityType
  pointsCost         Int?
  displayType        VoucherDisplayType @default(STANDARD)
  priority           Int                @default(0)
  merchant           Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId         String
  reward             Reward?            @relation("CouponReward", fields: [rewardId], references: [id])
  rewardId           String?
  validFrom          DateTime
  validUntil         DateTime
  maxUsesPerUser     Int?
  totalQuantity      Int?
  assignToUserId     String?
  exclusivityGroups  String[]

  // Multi-buy fields
  buyQuantity Int?
  getQuantity Int?

  // Discount fields (legacy - use reward instead)
  discountType  DiscountType?
  discountValue Float?

  // Day of week fields
  dayOfWeek String?

  // Threshold discount fields
  thresholdAmount Float?
  discountAmount  Float?

  // Item specific fields
  itemName    String?
  itemBarcode String?

  // Birthday fields
  daysBeforeBirthday Int?
  daysAfterBirthday  Int?

  // Activity fields
  activityType String?

  isActive         Boolean       @default(true)
  currentUses      Int           @default(0)
  usesPerUserLimit Int?
  globalUsageLimit Int?
  isStackable      Boolean       @default(false)
  userCoupons      UserCoupon[]
  couponUsages     CouponUsage[]
  storeOverrides   CouponStoreOverride[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([code, merchantId])
}

model UserCoupon {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  coupon    Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId  String
  qrCode    String    @unique @default(uuid())
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, couponId])
}

// Merchant-specific Points System
model UserMerchantPointBalance {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId      String
  totalPoints     Int      @default(0)
  availablePoints Int      @default(0)
  lockedPoints    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, merchantId])
}

model MerchantPointTransaction {
  id                     String                @id @default(uuid())
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String
  merchant               Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId             String
  merchantPointsProgram   MerchantPointsProgram? @relation(fields: [merchantPointsProgramId], references: [id], onDelete: SetNull)
  merchantPointsProgramId String?
  type                   TransactionType
  amount                 Int
  description            String
  referenceId            String? // ID powiązanego obiektu (coupon, stamp, etc.)
  referenceType          String? // Typ powiązanego obiektu
  balanceBefore          Int
  balanceAfter           Int
  merchantStore           MerchantStore? @relation(fields: [merchantStoreId], references: [id])
  merchantStoreId         String?
  createdAt              DateTime              @default(now())

  @@index([userId])
  @@index([merchantId])
  @@index([merchantPointsProgramId])
  @@index([merchantStoreId])
}

// Enhanced Coupon Usage Tracking
model CouponUsage {
  id            String   @id @default(uuid())
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId      String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  usedAt        DateTime @default(now())
  remainingUses Int?
  metadata      Json?
  merchantStore   MerchantStore? @relation(fields: [merchantStoreId], references: [id])
  merchantStoreId String?

  @@index([couponId])
  @@index([userId])
  @@index([merchantStoreId])
}

model RewardStoreOverride {
  id              String           @id @default(uuid())
  reward          Reward           @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  rewardId        String
  merchantStore   MerchantStore    @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
