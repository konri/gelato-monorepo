// Push Notifications System
enum NotificationCategory {
  GENERAL
  PROMOTIONS
  SECURITY
}

enum NotificationType {
  // GENERAL - User activities & rewards
  STAMP_ADDED
  STAMP_CARD_COMPLETED
  STAMP_MILESTONE_REACHED
  POINTS_EARNED
  POINTS_SPENT
  COUPON_CLAIMED
  VOUCHER_PURCHASED
  BIRTHDAY_REWARD
  REFERRAL_COMPLETED
  REFERRAL_REWARD_EARNED
  REWARD_UNLOCKED
  ACHIEVEMENT_UNLOCKED

  // PROMOTIONS - Marketing & offers
  COUPON_AVAILABLE
  COUPON_EXPIRING
  VOUCHER_EXPIRING
  MERCHANT_PROMOTION
  SPECIAL_OFFER
  NEW_REWARD_AVAILABLE
  FLASH_SALE
  LIMITED_TIME_OFFER

  // SECURITY - Account & security alerts
  NEW_LOGIN
  NEW_DEVICE
  PASSWORD_CHANGED
  EMAIL_CHANGED
  SUSPICIOUS_ACTIVITY
  ACCOUNT_LOCKED
  TWO_FACTOR_ENABLED

  // SYSTEM - App updates & reminders
  APP_UPDATE_AVAILABLE
  MAINTENANCE_SCHEDULED
  SYSTEM_ANNOUNCEMENT
  EVENT_REMINDER
  SUBSCRIPTION_EXPIRING
  PAYMENT_FAILED
  TERMS_UPDATED

  // ORDER - Order notifications
  ORDER_READY
}

model Notification {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  category NotificationCategory @default(GENERAL)
  type     NotificationType
  title    String
  message  String
  imageUrl String?
  metadata Json?

  isRead Boolean   @default(false)
  readAt DateTime?
  isSent Boolean   @default(false)
  sentAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, category])
  @@index([userId, createdAt])
}

model UserDevice {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  fcmToken   String
  platform   String
  deviceId   String
  deviceName String?

  isActive   Boolean  @default(true)
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([fcmToken])
}

// ─── Order Notification System ───────────────────────────────────────────────

enum OrderStatus {
  PREPARING
  DELAYED
  READY
  PICKED_UP
  CANCELLED
}

enum OrderPickUpSource {
  MANUAL
  AUTO_AFTER_READY_DELAY
}

model Order {
  id              String             @id @default(uuid())
  merchantStore   MerchantStore      @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId String
  orderNumber     Int
  status          OrderStatus        @default(PREPARING)
  userId          String?            // nullable — Mode 1 (app user) only
  sessionToken    String?            // nullable — Mode 2 (web session) only
  phoneNumber     String?            // nullable — Mode 4 (phone order) only
  orderDate       DateTime           // calendar date in merchant-local timezone
  pickupCode      String?            // orderNumber + 2 random letters (e.g. "45AB")
  pickedUpSource  OrderPickUpSource?
  pickedUpAt      DateTime?
  readyAt         DateTime?          // timestamp when order was marked READY
  note            String?
  statusHistory   Json               @default("[]")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([merchantStoreId, createdAt])
  @@index([merchantStoreId, status])
  @@index([sessionToken])
  @@index([userId])
  @@index([pickupCode])
  @@index([phoneNumber])
}

model OrderCounter {
  id              String        @id @default(uuid())
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId String
  date            DateTime      @db.Date
  lastNumber      Int           @default(0)
  updatedAt       DateTime      @updatedAt

  @@unique([merchantStoreId, date])
}

model WebOrderSession {
  id                  String                           @id @default(uuid())
  sessionToken        String                           @unique
  merchantStore       MerchantStore                    @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId     String
  createdAt           DateTime                         @default(now())
  expiresAt           DateTime
  webPushSubscription WebOrderSessionWebPushSubscription?

  @@index([sessionToken])
  @@index([expiresAt])
}

model WebOrderSessionWebPushSubscription {
  id               String          @id @default(uuid())
  sessionToken     String          @unique
  webOrderSession  WebOrderSession @relation(fields: [sessionToken], references: [sessionToken], onDelete: Cascade, onUpdate: Cascade)
  endpoint         String
  p256dh           String
  auth             String
  expirationTime   Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// ─── Order History (backup and statistics) ──────────────────────────────────

model OrderHistory {
  id              String             @id @default(uuid())
  orderId         String
  merchantStore   MerchantStore      @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId String
  orderNumber     Int
  status          OrderStatus
  userId          String?
  sessionToken    String?
  phoneNumber     String?
  orderDate       DateTime
  pickupCode      String?
  pickedUpSource  OrderPickUpSource?
  pickedUpAt      DateTime?
  readyAt         DateTime?
  note            String?
  createdAt       DateTime
  completedAt     DateTime           @default(now())

  @@index([merchantStoreId, completedAt])
  @@index([userId, completedAt])
  @@index([orderDate])
  @@index([status])
  @@index([phoneNumber])
}

// ─── Favorite Stores ─────────────────────────────────────────────────────────

model FavoriteStore {
  id              String        @id @default(uuid())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId String
  createdAt       DateTime      @default(now())

  @@unique([userId, merchantStoreId])
  @@index([userId])
}
