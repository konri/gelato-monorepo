enum FormType {
  COMPANY
  MERCHANT
  MERCHANT_STORE
  SUBSCRIPTION
}

model FormDraft {
  id        String            @id @default(uuid())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  formType  FormType
  formData  Json
