  @@unique([userId, streakProgramId, idempotencyKey], name: "UniqueUserStreakVisitIdempotency")
  @@index([merchantId, localDate])
  @@index([merchantStoreId])
}

model StreakRewardClaim {
  id               String            @id @default(uuid())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  merchant         Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId       String
  streakProgram    StreakProgram     @relation(fields: [streakProgramId], references: [id], onDelete: Cascade)
  streakProgramId  String
  reward           Reward?           @relation(fields: [rewardId], references: [id])
  rewardId         String?
