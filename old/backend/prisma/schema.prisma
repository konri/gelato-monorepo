generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("DATABASE_URL_SHADOW")
}

model User {
  id                            String                          @id @default(uuid())
  email                         String                          @unique
  name                          String?
  password                      String
  profileId                     String?
  profileType                   String?
  gender                        String?
  picture                       String?
  roles                         Role[]
  registrationSource            RegistrationSource?
  phone                         String?
  birthDate                     DateTime?
  aditionalEmial                String?
  language                      Language                        @default(PL)
  firstName                     String?
  surname                       String?
  emailVerified                 Boolean                         @default(false)
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  UploadedFiles                 UploadedFile[]
  UsedVoucher                   UsedVoucher[]
  ResetPassword                 ResetPassword[]
  EmailVerification             EmailVerification[]
  Feedback                      Feedback[]
  NotificationToken             NotificationToken[]
  Cooperator                    Cooperator?
  company                       Company?
  Client                        Client?
  CompanyOwner                  CompanyOwner?
  reciverNotifications          NotificationList[]              @relation("receiver")
  createNotifications           NotificationList[]              @relation("creator")
  File                          File[]
  EnterpriseForm                EnterpriseForm[]
  EnteriseFormRenewSubscription EnteriseFormRenewSubscription[]
  referralCode                  UserReferralCode?
  referralsGiven                Referral[]                      @relation("Referrer")
  referralReceived              Referral?                       @relation("Referred")
  userMerchantVouchers          UserMerchantVoucher[]
  userPointVouchers             UserPointVoucher[]
  pointBalance                  UserPointBalance?
  pointTransactions             PointTransaction[]
  loyaltyStampCards             LoyaltyStampCard[]
  stampTransactions             StampTransaction[]
  userCoupons                   UserCoupon[]
  merchantPointBalances         UserMerchantPointBalance[]
  merchantPointTransactions     MerchantPointTransaction[]
  couponUsages                  CouponUsage[]
  tokenVersion                  Int                             @default(0)
  locationPermission            Boolean                         @default(false)
  notificationPermission        Boolean                         @default(false)
  preferredCity                 String?
  isFirstTimeGoogleLogin        Boolean                         @default(true)
  profileSetupProgress          ProfileSetupProgress?
  formDrafts                    FormDraft[]
  notifications                 Notification[]
  devices                       UserDevice[]
  streakStates                  UserStreakState[]
  streakVisits                  StreakVisit[]
  streakRewardClaims            StreakRewardClaim[]
  createdCooperatorInvitations  CooperatorInvitation[]          @relation("CooperatorInvitationCreatedBy")
  favoriteStores                FavoriteStore[]
  userMerchantActivitySnapshots UserMerchantActivitySnapshot[]

  @@unique([profileId, profileType], name: "externalUserProvider")
}

enum Role {
  CLIENT
  OWNER
  COOPERATOR
  ADMIN
  DISACTIVE
  NEW_USER
}

enum RegistrationSource {
  WEB_MERCHANT
  WEB_CLIENT
  MOBILE_MERCHANT
  MOBILE_CLIENT
}

enum Language {
  PL
  EN
  SK // Slovak
  SL // Slovenian
  SV // Swedish
  DE // German
  PT // Portuguese
  UA // Ukraine
}

enum CooperatorType {
  OTHER
}

enum OperatorScopeMode {
  FULL_MERCHANT
  STORE_SCOPED
}

enum OperatorPermission {
  COMPANY_READ
  COMPANY_WRITE
  MERCHANT_PROFILE_READ
  MERCHANT_PROFILE_WRITE
  COOPERATOR_MANAGE
  INVITATION_MANAGE
  STORE_READ
  STORE_WRITE
  STAMP_TEMPLATE_READ
  STAMP_TEMPLATE_BASE_WRITE
  REWARD_READ
  REWARD_BASE_WRITE
  REWARD_OVERRIDE_WRITE
  COUPON_READ
  COUPON_BASE_WRITE
  COUPON_OVERRIDE_WRITE
  STREAK_READ
  STREAK_BASE_WRITE
  STREAK_OVERRIDE_WRITE
  POINTS_PROGRAM_READ
  POINTS_PROGRAM_WRITE
}

model Cooperator {
  id                String              @id @default(uuid())
  user              User                @relation(fields: [userId], references: [id])
  userId            String              @unique
  type              CooperatorType?
  companies         Company[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  CooperatorCompany CooperatorCompany[]
}

model Client {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyOwner {
  id          String              @id @default(uuid())
  user        User                @relation(fields: [userId], references: [id])
  userId      String              @unique
  company     Company             @relation(fields: [companyId], references: [id])
  companyId   String              @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  cooperators CooperatorCompany[]
  invitations CooperatorInvitation[]
}

model CooperatorCompany {
  id             String       @id @default(uuid())
  displayName    String
  cooperator     Cooperator   @relation(fields: [cooperatorId], references: [id])
  cooperatorId   String
  companyOwner   CompanyOwner @relation(fields: [companyOwnerId], references: [id])
  companyOwnerId String
  scopeMode      OperatorScopeMode    @default(FULL_MERCHANT)
  permissions    OperatorPermission[] @default([])
  storeScopeAll  Boolean              @default(true)
  storeAccesses  CooperatorCompanyStoreAccess[]
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([cooperatorId, companyOwnerId], name: "CollabToCompany")
  @@index([companyOwnerId, deletedAt])
  @@index([cooperatorId, deletedAt])
}

model CooperatorCompanyStoreAccess {
  id                  String            @id @default(uuid())
  cooperatorCompany   CooperatorCompany @relation(fields: [cooperatorCompanyId], references: [id], onDelete: Cascade)
  cooperatorCompanyId String
  merchantStore       MerchantStore     @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId     String
  createdAt           DateTime          @default(now())

  @@unique([cooperatorCompanyId, merchantStoreId], name: "UniqueCooperatorCompanyStoreAccess")
  @@index([merchantStoreId])
}

model CooperatorInvitation {
  id              String                           @id @default(uuid())
  email           String
  tokenHash       String                           @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  scopeMode       OperatorScopeMode                @default(FULL_MERCHANT)
  permissions     OperatorPermission[]            @default([])
  storeScopeAll   Boolean                          @default(true)
  companyOwner    CompanyOwner                     @relation(fields: [companyOwnerId], references: [id], onDelete: Cascade)
  companyOwnerId  String
  merchant        Merchant?                        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId      String?
  createdByUser   User                             @relation("CooperatorInvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdByUserId String
  storeAccesses   CooperatorInvitationStoreAccess[]
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt

  @@index([email])
  @@index([companyOwnerId, revokedAt, acceptedAt, expiresAt])
}

model CooperatorInvitationStoreAccess {
  id              String               @id @default(uuid())
  invitation      CooperatorInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  invitationId    String
  merchantStore   MerchantStore        @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId String
  createdAt       DateTime             @default(now())

  @@unique([invitationId, merchantStoreId], name: "UniqueInvitationStoreAccess")
  @@index([merchantStoreId])
}

model Company {
  id                            String                          @id @default(uuid())
  user                          User                            @relation(fields: [userId], references: [id])
  userId                        String                          @unique
  name                          String
  description                   String?
  taxId                         String?
  logo                          UploadedFile?                   @relation(fields: [logoId], references: [id])
  logoId                        String?
  address                       String
  city                          String
  country                       String
  cityOperate                   String[]
  postalCode                    String?
  phone                         String?
  email                         String?
  website                       String?
  facebook                      String?
  tiktok                        String?
  instagram                     String?
  companyOwner                  CompanyOwner?
  cooperators                   Cooperator[]
  subscription                  SubscriptionCompany?
  merchant                      Merchant?
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  HistorySubscriptionCompany    HistorySubscriptionCompany[]
  EnteriseFormRenewSubscription EnteriseFormRenewSubscription[]
}

model SubscriptionCompany {
  id                String   @id @default(uuid())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         String   @unique
  plan              Plan     @relation(fields: [planId], references: [id])
  planId            String
  startDate         DateTime
  endDate           DateTime
  promoCode         String?
  originalAppUserId String?
  identifier        String?
  autoRenewal       Boolean  @default(false)
  store             String?
  firstSeen         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EnterpriseForm {
  id          String   @id @default(uuid())
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  name        String
  surname     String
  company     String
  email       String
  mobile      String?
  amountUsers Int      @default(1)
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EnteriseFormRenewSubscription {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  email     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HistorySubscriptionCompany {
  id                String   @id @default(uuid())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         String
  plan              Plan     @relation(fields: [planId], references: [id])
  planId            String
  startDate         DateTime
  endDate           DateTime
  promoCode         String?
  originalAppUserId String?
  identifier        String?
  autoRenewal       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Voucher {
  id           String   @id @default(uuid())
  code         String   @unique
  amountMax    Int      @default(1)
  plan         Plan     @relation(fields: [planId], references: [id])
  planId       String
  amountMonths Int
  details      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Plan {
  id                         String                       @id @default(uuid())
  paymentCode                String                       @unique
  name                       String
  description                String?
  mostPopular                Boolean                      @default(false)
  amountMembers              Int
  privatePlan                Boolean                      @default(false)
  subscriptionCompany        SubscriptionCompany[]
  vouchers                   Voucher[]
  HistorySubscriptionCompany HistorySubscriptionCompany[]
}

model UsedVoucher {
  id        String   @id @default(uuid())
  code      String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, userId], name: "only_one_code_for_user")
}

model PromoCode {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  paymentCode String
  description String
  userName    String?
}

model TeamMate {
  id          String   @id @default(uuid())
  name        String
  title       String
  photoPath   String
  description String
  instagram   String
  facebook    String
  web         String
  linkedin    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UploadedFile {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  projectId    String?
  fileName     String
  filePath     String    @unique
  filePreview  String    @default("")
  fileMimeType String
  size         Int
  eTag         String
  bucket       String
  key          String
  createdAt    DateTime  @default(now())
  Company      Company[]
  File         File[]
}

model ResetPassword {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  code      String   @unique
  createdAt DateTime @default(now())
}

model Feedback {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  topic     String
  comment   String
  email     String   @default("none")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationList {
  id               String   @id @default(uuid())
  user             User     @relation("receiver", fields: [userId], references: [id])
  userId           String
  creator          User?    @relation("creator", fields: [creatorId], references: [id])
  creatorId        String?
  title            String
  body             String
  image            String?
  isRead           Boolean  @default(false)
  additionalParams Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum FileType {
  IMAGE
  PDF
  VIDEO
  OTHER
}

model File {
  id            String         @id @default(uuid())
  creator       User           @relation(fields: [creatorId], references: [id])
  creatorId     String
  title         String
  description   String?
  uploadedFiles UploadedFile[]
  fileTypes     FileType[]
  lastUpdate    DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model NotificationToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token], name: "UniqueToken")
}

// todo: Offline list to better performance, put the last id to the table and check from mobile if is something new

model Referral {
  id             String   @id @default(uuid())
  referrer       User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId     String
  referredUser   User     @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)
  referredUserId String   @unique
  referralCode   String
  pointsAwarded  Int      @default(0)
  isCompleted    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserReferralCode {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  description    String?
  iconUrl        String?
  iconPngUrl     String?
  merchants      Merchant[]
  merchantStores MerchantStore[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Merchant {
  id                        String                     @id @default(uuid())
  name                      String
  slug                      String                     @unique
  description               String?
  logoUrl                   String?
  coverUrl                  String?
  iconUrl                   String?
  category                  Category                   @relation(fields: [categoryId], references: [id])
  categoryId                String
  company                   Company?                   @relation(fields: [companyId], references: [id])
  companyId                 String?                    @unique
  isVerified                Boolean                    @default(false)
  verifiedAt                DateTime?
  verifiedBy                String?
  isActive                  Boolean                    @default(true)
  rewardProximityThreshold  Int                        @default(50) // Points threshold for "close to reward"
  stampProximityThreshold   Int                        @default(2) // Stamps threshold for "close to reward"
  stores                    MerchantStore[]
  vouchers                  MerchantVoucher[]
  coupons                   Coupon[]
  stampCards                LoyaltyStampCard[]
  stampTemplates            LoyaltyStampCardTemplate[]
  pointsProgram             MerchantPointsProgram?
  userMerchantPointBalances UserMerchantPointBalance[]
  merchantPointTransactions MerchantPointTransaction[]
  rewards                   Reward[]
  streakPrograms            StreakProgram[]
  streakStates              UserStreakState[]
  streakVisits              StreakVisit[]
  streakRewardClaims        StreakRewardClaim[]
  cooperatorInvitations     CooperatorInvitation[]
  userMerchantActivitySnapshots UserMerchantActivitySnapshot[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
}

model UserMerchantActivitySnapshot {
  userId         String
  merchantId     String
  firstActiveAt  DateTime
  lastActiveAt   DateTime
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant       Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@id([userId, merchantId])
  @@index([merchantId, lastActiveAt])
}

model MerchantPointsProgram {
  id            String   @id @default(uuid())
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId    String   @unique
  amountSpent   Float
  pointsAwarded Int
  cardMessage   String?
  isActive      Boolean  @default(true)
  transactions  MerchantPointTransaction[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MerchantStore {
  id               String            @id @default(uuid())
  merchant         Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId       String
  category         Category?         @relation(fields: [categoryId], references: [id])
  categoryId       String?
  name             String
  description      String?
  address          String
  city             String
  country          String            @default("Poland")
  postalCode       String?
  phone            String?
  email            String?
  hours            String?
  latitude         Float?
  longitude        Float?
  logoUrl          String?
  photoUrl         String?
  images           Json?             @default("[]")
  merchantVouchers MerchantVoucher[]
  rewardOverrides             RewardStoreOverride[]
  couponOverrides             CouponStoreOverride[]
  streakProgramOverrides      StreakProgramStoreOverride[]
  cooperatorCompanyAccesses    CooperatorCompanyStoreAccess[]
  cooperatorInvitationAccesses CooperatorInvitationStoreAccess[]
  orders               Order[]
  orderCounters        OrderCounter[]
  orderHistory         OrderHistory[]
  webOrderSessions     WebOrderSession[]
  favoriteByUsers      FavoriteStore[]
  stampTransactions          StampTransaction[]
  merchantPointTransactions  MerchantPointTransaction[]
  couponUsages               CouponUsage[]
  streakVisits               StreakVisit[]
  isActive         Boolean           @default(true)

  orderQueueConfig MerchantStoreOrderQueueConfig?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model MerchantStoreOrderQueueConfig {
  id                       String        @id @default(uuid())
  merchantStore            MerchantStore @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  merchantStoreId          String        @unique
  orderArchiveDelayMs      Int           @default(1800000)
  maxActiveOrders          Int           @default(500)
  webSessionTtlMs          Int           @default(7200000)
  orderReadyPushTitle      String?
  orderReadyPushBody       String?
  orderNumberRolloverAfter Int           @default(100)
  autoPickUpAfterReady     Boolean       @default(true)
  orderReadyReminderEnabled   Boolean    @default(false)
  orderReadyReminderDelayMs   Int        @default(900000)
  requirePickupCode        Boolean       @default(true)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
}

enum VoucherDisplayType {
  HOT
  PROMOTED
  STANDARD
}

model MerchantVoucher {
  id                   String                @id @default(uuid())
  merchant             Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId           String
  store                MerchantStore?        @relation(fields: [storeId], references: [id])
  storeId              String?
  title                String
  description          String?
  value                Int
  pointsCost           Int
  imageUrl             String?
  displayType          VoucherDisplayType    @default(STANDARD)
  priority             Int                   @default(0)
  userMerchantVouchers UserMerchantVoucher[]
  isActive             Boolean               @default(true)
  validFrom            DateTime?
  validUntil           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model UserMerchantVoucher {
  id                String          @id @default(uuid())
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  merchantVoucher   MerchantVoucher @relation(fields: [merchantVoucherId], references: [id], onDelete: Cascade)
  merchantVoucherId String
  qrCode            String          @unique
  isUsed            Boolean         @default(false)
  usedAt            DateTime?
  validUntil        DateTime
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum VoucherType {
  SINGLE_SERVICE // Jedna usługa za ustaloną cenę
  MULTI_USE // Wielokrotnego użytku
  SERVICE_PACKAGE // Pakiet usług
  DISCOUNT_PERCENT // Procentowa zniżka
  CASH_EQUIVALENT // Ekwiwalent pieniężny
}

model PointVoucher {
  id                String             @id @default(uuid())
  code              String             @unique
  title             String
  description       String?
  voucherType       VoucherType        @default(SINGLE_SERVICE)
  pointsCost        Int
  maxUses           Int                @default(1)
  currentUses       Int                @default(0)
  isActive          Boolean            @default(true)
  validFrom         DateTime?
  validUntil        DateTime?
  metadata          Json? // Elastyczne dane dla różnych typów voucherów
  userPointVouchers UserPointVoucher[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model UserPointVoucher {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  pointVoucher   PointVoucher @relation(fields: [pointVoucherId], references: [id], onDelete: Cascade)
  pointVoucherId String
  qrCode         String       @unique
  isUsed         Boolean      @default(false)
  usedAt         DateTime?
  validUntil     DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum TransactionType {
  EARNED // Zdobyte punkty
  SPENT // Wydane punkty
  REFUND // Zwrot punktów
  BONUS // Bonus punkty
  PENALTY // Kara punkty
}

model UserPointBalance {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @unique
  totalPoints     Int      @default(0)
  availablePoints Int      @default(0)
  lockedPoints    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PointTransaction {
  id            String          @id @default(uuid())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  type          TransactionType
  amount        Int
  description   String
  referenceId   String? // ID powiązanego obiektu (voucher, referral, etc.)
  referenceType String? // Typ powiązanego obiektu
  balanceBefore Int
  balanceAfter  Int
  createdAt     DateTime        @default(now())
}

model VoucherHistory {
  id           String   @id @default(uuid())
  userId       String
  voucherType  String // 'POINT_VOUCHER' | 'MERCHANT_VOUCHER' | 'SUBSCRIPTION_VOUCHER'
  voucherId    String
  voucherCode  String
  voucherTitle String
  action       String // 'PURCHASED' | 'USED' | 'EXPIRED' | 'REFUNDED'
  pointsSpent  Int?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([voucherType])
  @@index([action])
}

// Loyalty Stamps System
// Universal Reward System
enum RewardSourceType {
  STAMP_CARD
  POINTS
  CASH
  SUBSCRIPTION
  REFERRAL
  ACTIVITY
}

enum RewardValueType {
  FREE_SERVICE
  DISCOUNT_PERCENT
  DISCOUNT_AMOUNT
  PRODUCT
  POINTS
  CASH_VOUCHER
}

enum UserRewardSourceType {
  STAMP_MAIN
  STAMP_MILESTONE
  STREAK
  COUPON
  POINT_VOUCHER
  MERCHANT_VOUCHER
}

enum UserRewardStatus {
  AVAILABLE
  CLAIMED
  REDEEMED
  EXPIRED
  CANCELLED
}

model Reward {
  id          String           @id @default(uuid())
  merchant    Merchant?        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId  String?
  title       String
  description String?
  imageUrl    String?
  sourceType  RewardSourceType // Skąd można dostać nagrodę
  valueType   RewardValueType // Typ wartości nagrody

  // Value fields (based on valueType)
  discountPercent Float?
  discountAmount  Float?
  pointsValue     Int?
  cashValue       Float?
  productName     String?

  // Limitations
  maxUsesPerUser Int?
  totalQuantity  Int?
  currentUses    Int  @default(0)

  // Validity
  isActive   Boolean   @default(true)
  validFrom  DateTime?
  validUntil DateTime?

  // Metadata
  metadata Json?

  // Relations
  stampTemplates     LoyaltyStampCardTemplate[]
  stampMilestones    StampMilestone[]
  coupons            Coupon[]                   @relation("CouponReward")
  streakPrograms     StreakProgram[]
  streakStages       StreakStage[]
  streakRewardClaims StreakRewardClaim[]
  storeOverrides     RewardStoreOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserReward {
  id                String               @id @default(uuid())
  userId            String
  merchantId        String?
  rewardId          String?
