  streakStageId    String?
  cycleNumber      Int
  claimedAt        DateTime          @default(now())
  createdAt        DateTime          @default(now())

  @@index([userId, streakProgramId])
  @@index([merchantId, claimedAt])
}

model LoyaltyStampCardTemplate {
  id                          String             @id @default(uuid())
  merchant                    Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId                  String
  title                       String
  description                 String?
  stampCoverUrl               String?
  stampStickerIconUrl         String?
  stampsRequired              Int                @default(10)
  awardType                   String? // "visit" | "amount"
  minimumAmount               Float?
  reward                      Reward?            @relation(fields: [rewardId], references: [id])
