  merchantStoreId         String
  name                    String?
  description             String?
  requiredConsecutiveDays Int?
  streakingInterval       Int?
  graceDays               Int?
  timezone                String?
  repeatable              Boolean?
  isActive                Boolean?
  updatedByUserId         String
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@unique([streakProgramId, merchantStoreId], name: "UniqueStreakProgramStoreOverride")
  @@index([merchantStoreId])
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Profile Setup Progress System
enum ProfileSetupStep {
  COMPANY // Krok 1: hasCompany
  MERCHANT // Krok 2: hasMerchant
  STORE // Krok 3: hasStore
  SUBSCRIPTION // Krok 4: hasSubscription
  COMPLETED // Ukończone
}

model ProfileSetupProgress {
  id             String             @id @default(uuid())
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String             @unique
  currentStep    ProfileSetupStep   @default(COMPANY)
  completedSteps ProfileSetupStep[]
