  claimedAt         DateTime?
  redeemedAt        DateTime?
  expiresAt         DateTime?
  pointsCost        Int?
  qrCode            String?
  payload           Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([userId, sourceType, sourceEntityId, sourceSubEntityId], name: "UniqueUserRewardSource")
  @@index([userId, status, merchantId, createdAt])
  @@index([merchantId, status, createdAt])
  @@index([rewardId])
}

enum StreakingPolicy {
  DAILY
  WEEKLY
  MONTHLY
}

enum StreakBenefitType {
  REWARD
  INFO_ONLY
  POINTS_MULTIPLIER
  FIXED_POINTS
}

model StreakProgram {
  id                      String              @id @default(uuid())
  merchant                Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId              String
  reward                  Reward?             @relation(fields: [rewardId], references: [id])
  rewardId                String?
  name                    String
  description             String?
  requiredConsecutiveDays Int
  streakingPolicy         StreakingPolicy     @default(DAILY)
  streakingInterval       Int                 @default(1)
  timezone                String?
  graceDays               Int                 @default(0)
  repeatable              Boolean             @default(false)
  isActive                Boolean             @default(true)
  deletedAt               DateTime?
  states                  UserStreakState[]
  visits                  StreakVisit[]
  rewardClaims            StreakRewardClaim[]
  stages                  StreakStage[]
  storeOverrides          StreakProgramStoreOverride[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@unique([merchantId, name])
  @@index([merchantId, isActive, deletedAt])
}

model StreakStage {
  id               String              @id @default(uuid())
  streakProgram    StreakProgram       @relation(fields: [streakProgramId], references: [id], onDelete: Cascade)
  streakProgramId  String
  benefitType      StreakBenefitType   @default(REWARD)
  reward           Reward?             @relation(fields: [rewardId], references: [id])
  rewardId         String?
  infoMessage      String?
  pointsMultiplier Float?
  pointsAmount     Int?
  dayThreshold     Int
  rewardClaims     StreakRewardClaim[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([streakProgramId, dayThreshold], name: "UniqueStreakStageThreshold")
  @@index([streakProgramId, dayThreshold])
}

model UserStreakState {
  id                    String        @id @default(uuid())
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String
  merchant              Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId            String
  streakProgram         StreakProgram @relation(fields: [streakProgramId], references: [id], onDelete: Cascade)
  streakProgramId       String
  currentStreak         Int           @default(0)
  lastVisitLocalDate    DateTime?
  longestStreak         Int           @default(0)
  claimableRewardsCount Int           @default(0)
  claimedCycles         Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([userId, streakProgramId], name: "UniqueUserStreakState")
  @@index([merchantId])
}

model StreakVisit {
  id              String        @id @default(uuid())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  merchant        Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
