model LoyaltyStampCard {
  id                String                    @id @default(uuid())
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  merchant          Merchant                  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
