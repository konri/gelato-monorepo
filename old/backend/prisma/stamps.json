{
  "info": {
    "_postman_id": "loyalty-stamps-collection",
    "name": "EasyBons - Loyalty Stamps API",
    "description": "Complete collection for Loyalty Stamps functionality",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api-dev.easybons.com:4000",
      "type": "string"
    },
    {
      "key": "merchant_id",
      "value": "9f1d20c8-19ef-4324-acb8-73d75c470fb4",
      "type": "string"
    },
    {
      "key": "template_id",
      "value": "b834af6a-3f3e-4cca-9e86-ac86396b3200",
      "type": "string"
    },
    {
      "key": "card_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "client_user_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. SZABLONY KART PIECZĄTEK",
      "item": [
        {
          "name": "Pobierz szablony kart merchanta - OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { myStampCardTemplates { id title description stampsRequired rewardTitle rewardDescription isActive merchant { id name } stampCards { id userId } createdAt } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Pobierz dostępne szablony - PUBLIC",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { availableStampCardTemplates(merchantId: \\\"{{merchant_id}}\\\") { id title description stampsRequired rewardTitle rewardDescription merchant { id name } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Debug - wszystkie szablony - PUBLIC",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { allStampCardTemplates { id title description stampsRequired isActive merchantId merchant { id name } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Utwórz szablon karty pieczątek - OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { createStampCardTemplate(data: { merchantId: \\\"{{merchant_id}}\\\", title: \\\"Kawa za darmo\\\", description: \\\"Zbierz 10 pieczątek i otrzymaj kawę gratis\\\", stampsRequired: 10, rewardTitle: \\\"Darmowa kawa\\\", rewardDescription: \\\"Jedna kawa dowolnego rodzaju\\\" }) { id title stampsRequired merchant { name } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Aktualizuj szablon karty - OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { updateStampCardTemplate(id: \\\"{{template_id}}\\\", data: { merchantId: \\\"{{merchant_id}}\\\", title: \\\"Nowy tytuł\\\", description: \\\"Nowy opis\\\", stampsRequired: 8 }) { id title stampsRequired } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Usuń szablon karty - OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { deleteStampCardTemplate(id: \\\"{{template_id}}\\\") }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        }
      ]
    },
    {
      "name": "2. KARTY UŻYTKOWNIKÓW",
      "item": [
        {
          "name": "Aktywuj kartę dla siebie (CLIENT) - CLIENT/OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { activateStampCard(merchantId: \\\"{{merchant_id}}\\\", templateId: \\\"{{template_id}}\\\") { id stampsRequired stampsCollected merchant { name } template { title rewardTitle } user { id email } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Aktywuj kartę bez szablonu - CLIENT/OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { activateStampCard(merchantId: \\\"{{merchant_id}}\\\") { id stampsRequired stampsCollected merchant { name } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Aktywuj kartę dla konkretnego użytkownika (OWNER dla clienta) - OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { activateStampCardForUser(userId: \\\"{{client_user_id}}\\\", merchantId: \\\"{{merchant_id}}\\\", templateId: \\\"{{template_id}}\\\") { id stampsRequired stampsCollected merchant { name } template { title rewardTitle } user { id email name } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Pobierz karty użytkownika - CLIENT/OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { myStampCards { id merchant { name } template { title rewardTitle } stampsCollected stampsRequired stamps { id isUsed createdAt } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        }
      ]
    },
    {
      "name": "3. ZARZĄDZANIE PIECZĄTKAMI",
      "item": [
        {
          "name": "Dodaj pieczątkę do karty - OWNER/COOPERATOR/ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { addStamp(cardId: \\\"{{card_id}}\\\", description: \\\"Zakup kawy\\\") { id cardId createdAt } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        }
      ]
    },
    {
      "name": "4. FUNKCJE ADMINISTRACYJNE",
      "item": [
