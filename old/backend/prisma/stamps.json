              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { fixStampCardDiscrepancy(cardId: \\\"{{card_id}}\\\") }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
