#!/bin/bash

echo "🚀 Deploying EasyBons API to DEV environment (api-dev.easybons.com)..."

# Konfiguracja
REMOTE_USER="kraczo"
REMOTE_HOST="s5.mydevil.net"
REMOTE_PATH="/usr/home/kraczo/api-dev-easybons"
LOCAL_PATH="."
PRISMA_ENGINE_PATH="./node_modules/.prisma/client/libquery_engine-freebsd14.so.node"
FETCH_ENGINE_SCRIPT="./prisma/scripts/fetch-prisma-engine.sh"

# Pliki do wykluczenia
EXCLUDE_FILE="/tmp/rsync_exclude_$$"
cat > "$EXCLUDE_FILE" << EOF
node_modules/*
!.prisma
.git/
.env
.env.local
prisma/.env
yarn-error.log
.DS_Store
*.log
coverage/
.nyc_output/
.vscode/
.idea/
EOF

echo "🔍 Checking TypeScript compilation..."
# Sprawdź kompilację TypeScript przed deployem
yarn tsc --noEmit || {
  echo "❌ TypeScript compilation failed. Fix errors before deploying."
  exit 1
}
echo "✅ TypeScript compilation successful!"

echo "📦 Building application locally (including Prisma)..."
# Najpierw instalacja zależności
yarn install --production=false || {
  echo "❌ Failed to run yarn install."
  exit 1
}
export PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1

# Uruchom postinstall, aby wygenerować pliki Prisma (bez binarki)
yarn postinstall || {
  echo "❌ Failed to run yarn postinstall."
  exit 1
}

# Uruchom fetch-prisma-engine.sh, aby skopiować binarkę
if [ -f "$FETCH_ENGINE_SCRIPT" ]; then
  echo "📥 Running fetch-prisma-engine.sh to ensure binary..."
  chmod +x "$FETCH_ENGINE_SCRIPT"
  "$FETCH_ENGINE_SCRIPT" || {
    echo "❌ Failed to run $FETCH_ENGINE_SCRIPT."
    exit 1
  }
else
  echo "❌ Fetch script ($FETCH_ENGINE_SCRIPT) not found. Please create it first."
  exit 1
fi

# Sprawdź, czy binarka istnieje przed ustawieniem zmiennej
if [ -f "$PRISMA_ENGINE_PATH" ]; then
  echo "✅ Prisma engine binary found at $PRISMA_ENGINE_PATH"
  export PRISMA_QUERY_ENGINE_LIBRARY="$PWD/node_modules/.prisma/client/libquery_engine-freebsd14.so.node"
  export PRISMA_CLI_QUERY_ENGINE_TYPE=library
  export PRISMA_CLIENT_ENGINE_TYPE=library
else
  echo "❌ Prisma engine binary not found at $PRISMA_ENGINE_PATH. Aborting."
  exit 1
fi

# Ponownie uruchom prisma-generate, aby upewnić się, że wszystkie pliki są poprawne
#yarn prisma-generate || {
#  echo "❌ Failed to run yarn prisma-generate."
#  exit 1
#}

# Sprawdź, czy folder node_modules/.prisma/client istnieje i zawiera pliki
if [ -d "node_modules/.prisma/client" ] && [ -f "node_modules/.prisma/client/libquery_engine-freebsd14.so.node" ]; then
  echo "✅ Prisma Client directory and engine binary found locally."
  ls -l node_modules/.prisma/client
else
  echo "❌ Prisma Client directory or engine binary missing. Aborting."
  exit 1
fi

# Debug: Sprawdź zawartość folderu node_modules/.prisma/client
echo "📋 Contents of node_modules/.prisma/client before upload:"
ls -l node_modules/.prisma/client

echo "📤 Uploading files to server..."
# Utwórz folder node_modules/.prisma na serwerze
ssh -T "$REMOTE_USER@$REMOTE_HOST" "mkdir -p $REMOTE_PATH/node_modules/.prisma" || {
  echo "❌ Failed to create directory $REMOTE_PATH/node_modules/.prisma on server."
  exit 1
}

# Upload plików na serwer (włącznie z dist, prisma/ i node_modules/.prisma)
rsync -avz --delete \
  --exclude-from="$EXCLUDE_FILE" \
  --progress \
  "$LOCAL_PATH/" \
  "$REMOTE_USER@$REMOTE_HOST:$REMOTE_PATH/" || {
  echo "❌ Failed to rsync project files to server."
  exit 1
}

# Osobno wgrywamy node_modules/.prisma/client
if [ -d "node_modules/.prisma/client" ]; then
  echo "📤 Uploading Prisma Client and engine binary..."
  rsync -avz --progress \
    "$LOCAL_PATH/node_modules/.prisma/client/" \
    "$REMOTE_USER@$REMOTE_HOST:$REMOTE_PATH/node_modules/.prisma/client/" || {
    echo "❌ Failed to rsync node_modules/.prisma/client to server."
    exit 1
  }
else
  echo "❌ Prisma Client directory (node_modules/.prisma/client) not found locally. Aborting."
  exit 1
fi

echo "🔧 Setting up environment on server..."
# Konfiguracja na serwerze
ssh -T "$REMOTE_USER@$REMOTE_HOST" << 'ENDSSH'
cd /usr/home/kraczo/api-dev-easybons

# Kopiowanie .env.dev do .env
cp .env.dev .env

# Usuwanie prisma/.env
rm -f prisma/.env

# Dodanie zmiennych środowiskowych dla Prisma do .env
echo "PRISMA_QUERY_ENGINE_LIBRARY=/usr/home/kraczo/api-dev-easybons/node_modules/.prisma/client/libquery_engine-freebsd14.so.node" >> .env
echo "PRISMA_CLI_QUERY_ENGINE_TYPE=library" >> .env
echo "PRISMA_CLIENT_ENGINE_TYPE=library" >> .env

# Ustaw uprawnienia dla binarnego silnika Prisma
if [ -f "/usr/home/kraczo/api-dev-easybons/node_modules/.prisma/client/libquery_engine-freebsd14.so.node" ]; then
  chmod 755 /usr/home/kraczo/api-dev-easybons/node_modules/.prisma/client/libquery_engine-freebsd14.so.node
else
  echo "❌ Prisma engine binary not found on server. Deployment may fail."
  exit 1
fi

# Debug: Sprawdź zawartość folderu node_modules/.prisma/client na serwerze
echo "📋 Contents of node_modules/.prisma/client on server:"
ls -l /usr/home/kraczo/api-dev-easybons/node_modules/.prisma/client

# Instalacja wszystkich zależności (pomijamy Puppeteer)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true yarn install --ignore-scripts

# Przebudowa binariów canvas i sharp - TEMPORARILY DISABLED
echo "🔨 Rebuilding native dependencies (canvas, sharp) - SKIPPED"
# Canvas and Sharp temporarily disabled to avoid deployment issues
echo "📝 Canvas and Sharp are disabled - avatar generation and image processing will be skipped"
# npm install canvas sharp --legacy-peer-deps --build-from-source || {
#   echo "⚠️ Method 1 failed, trying yarn..."
#   yarn add canvas sharp || {
#     echo "⚠️ Yarn failed, trying without canvas/sharp..."
#     echo "📝 Canvas and Sharp will be skipped - QR codes may not work"
#   }
# }

echo "🔄 Restarting application with PM2..."
# Restartuj proces PM2, jeśli istnieje, lub uruchom nowy
/usr/home/kraczo/api-dev-easybons/node_modules/.bin/pm2 restart api-easybons || /usr/home/kraczo/api-dev-easybons/node_modules/.bin/pm2 start dist/index.js --name api-easybons >> api.log 2>&1
sleep 3
# Zapisz konfigurację PM2
/usr/home/kraczo/api-dev-easybons/node_modules/.bin/pm2 save
# Sprawdź status
/usr/home/kraczo/api-dev-easybons/node_modules/.bin/pm2 list
echo "✅ Application restarted with PM2!"
echo "📋 Logs: ssh kraczo@s5.mydevil.net 'cd /usr/home/kraczo/api-dev-easybons && /usr/home/kraczo/api-dev-easybons/node_modules/.bin/pm2 logs api-easybons'"

echo "✅ DEV deployment completed!"
echo "🌐 Application available at: https://api-dev.easybons.com/graphql"
ENDSSH

# Czyszczenie
rm -f "$EXCLUDE_FILE"

echo "🎉 Deployment to DEV environment completed successfully!"
echo "🔗 Your API is available at: https://api-dev.easybons.com"