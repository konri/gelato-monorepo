{
  "name": "typegraphql-example",
  "license": "MIT",
  "scripts": {
    "old_local": "ts-node-dev --respawn --no-notify --transpileOnly src/index.ts",
    "tunnel": "ssh -N -L 5433:pgsql5.mydevil.net:5432 kraczo@s5.mydevil.net",
    "dev": "cp .env.dev .env && rm -f prisma/.env && ts-node-dev --respawn --no-notify --transpileOnly src/index.ts",
    "dev-tunnel": "./set_tunnel_for_dev_db",
    "local": "cp .env.local .env && rm -f prisma/.env && ts-node-dev --respawn --no-notify --transpileOnly src/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest --watch",
    "coverage": "jest --coverage",
    "prisma-generate": "PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma generate",
    "prisma-migrate": "prisma migrate save --experimental && prisma migrate up --experimental",
    "migrate-db-local": "cp .env.local .env && prisma migrate dev",
    "migrate-db-dev": "./prisma/migrate_with_tunnel",
    "seed-db-local": "cp .env.local .env && npx prisma db seed",
    "seed-db-dev": "./prisma/seed_with_tunnel",
    "reset-db-run-seed-local": "cp .env.local .env && npx prisma migrate reset",
    "reset-db-run-seed-dev": "yarn drop-all-tunnel && yarn deploy-dev-db-tunnel && yarn seed-db-tunnel-dev",
    "deploy-db-local": "cp .env.local .env && prisma migrate deploy",
    "deploy-db-dev": "cp .env.dev .env && prisma migrate deploy",
    "seed-db-tunnel-dev": "prisma/seed_with_tunnel",
    "deploy-dev-db-tunnel": "prisma/deploy_with_tunnel",
    "drop-all-tunnel": "./prisma/drop_all_with_tunnel",
    "deploy-dev": "./deploy-dev",
    "deploy-dev-no-prisma": "./deploy-dev-mydevil-compiled",
    "start-node": "node dist/index.js",
    "start": "pm2 start dist/index.js --name api-easybons",
    "stop": "pm2 stop api-easybons",
    "logs": "pm2 logs api-easybons --lines 60",
    "restart-pm2": "pm2 restart api-easybons",
    "postinstall": "rm -f prisma/.env && PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 yarn prisma-generate && tsc && cp -R src/public dist && cp -R src/Config dist && cp -R src/locales dist",
    "localstack:config": "aws --endpoint-url=http://localhost:4572 s3 mb s3://demo-bucket && aws --endpoint-url=http://localhost:4572 s3api put-bucket-acl --bucket demo-bucket --acl public-read",
    "localstack:checkfiles": "aws --endpoint-url=http://localhost:4572 s3 ls demo-bucket"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "6.12.0",
    "@nicokaiser/passport-apple": "^1.0.1",
    "@prisma/client": "^5.16.1",
    "@sendgrid/mail": "^7.6.2",
    "@sentry/node": "^7.1.1",
    "@sentry/tracing": "^7.1.1",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/tmp": "^0.2.6",
    "apollo-server-express": "^3.13.0",
    "aws-sdk": "^2.797.0",
    "axios": "^1.13.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.69.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^8.2.0",
    "express": "^4.19.2",
    "firebase": "^10.12.3",
    "firebase-admin": "12.7.0",
    "fluent-ffmpeg": "^2.1.2",
    "google-auth-library": "^9.15.1",
    "googleapis": "126.0.1",
    "graphql": "14.6.0",
    "graphql-type-json": "^0.3.2",
    "i18next": "^22.5.1",
    "i18next-fs-backend": "^2.3.1",
    "i18next-node-fs-backend": "^2.1.3",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "9.0.2",
    "jwt-decode": "^3.1.2",
    "multer": "^1.4.2",
    "music-metadata": "^7.13.4",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.8",
    "passport": "^0.4.1",
    "passport-custom": "^1.1.1",
    "passport-facebook": "latest",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "latest",
    "passport-local": "^1.0.0",
    "pm2": "^5.4.2",
    "prisma": "^5.16.1",
    "reflect-metadata": "0.1.13",
    "stripe": "^14.3.0",
    "thymeleaf": "^0.21.0",
    "tmp": "^0.2.3",
    "twilio": "^6.0.0",
    "type-graphql": "0.17.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/graphql": "14.5.0",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^26.0.15",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/multer": "^1.4.4",
    "@types/node": "12.12.62",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.4",
    "@types/passport-facebook": "^2.1.10",
    "@types/passport-google-oauth20": "^2.0.4",
    "@types/passport-jwt": "^3.0.3",
    "@types/passport-local": "^1.0.33",
    "@types/web-push": "^3.6.4",
    "@types/ws": "7.2.3",
    "eslint": "^7.9.0",
    "eslint-config-airbnb-typescript-prettier": "^3.1.0",
    "eslint-plugin-graphql": "^4.0.0",
    "husky": "^4.3.0",
    "jest": "^26.6.3",
    "prettier": "^2.1.2",
    "pretty-quick": "^3.0.2",
    "ts-jest": "^26.4.4",
    "ts-node": "9.0.0",
    "ts-node-dev": "1.0.0-pre.44",
    "typescript": "^5.4.5"
  },
  "resolutions": {
    "@types/serve-static": "1.15.7"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
