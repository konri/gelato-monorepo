{
  "family": "bonapka-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::190275053744:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::190275053744:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "bonapka-backend",
      "image": "190275053744.dkr.ecr.eu-central-1.amazonaws.com/bonapka-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "ENVIRONMENT", "value": "production" },
        { "name": "PORT", "value": "5000" },
        { "name": "REDIS_ENABLED", "value": "true" },
        { "name": "AWS_S3_SERVER_ENDPOINT", "value": "https://s3.eu-central-1.amazonaws.com" },
        { "name": "AWS_S3_FILE_CODE", "value": "prod" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/DATABASE_URL"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/JWT_SECRET"
        },
        {
          "name": "BE_JWT",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/BE_JWT"
        },
        {
          "name": "SENTRY_DSN",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/SENTRY_DSN"
        },
        {
          "name": "FACEBOOK_APP_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FACEBOOK_APP_ID"
        },
        {
          "name": "FACEBOOK_APP_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FACEBOOK_APP_SECRET"
        },
        {
          "name": "FACEBOOK_CALLBACK",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FACEBOOK_CALLBACK"
        },
        {
          "name": "GOOGLE_APP_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/GOOGLE_APP_ID"
        },
        {
          "name": "GOOGLE_APP_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/GOOGLE_APP_SECRET"
        },
        {
          "name": "GOOGLE_CALLBACK",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/GOOGLE_CALLBACK"
        },
        {
          "name": "SMTP_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/SMTP_HOST"
        },
        {
          "name": "SMTP_PORT",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/SMTP_PORT"
        },
        {
          "name": "SMTP_USER",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/SMTP_USER"
        },
        {
          "name": "SMTP_PASS",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/SMTP_PASS"
        },
        {
          "name": "SMTP_FROM",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/SMTP_FROM"
        },
        {
          "name": "AWS_BUCKET_NAME",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/AWS_BUCKET_NAME"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/REDIS_URL"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/AWS_ACCESS_KEY_ID"
        },
        {
          "name": "AWS_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/AWS_SECRET_KEY"
        },
        {
          "name": "BACKEND_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/BACKEND_HOST"
        },
        {
          "name": "FIREBASE_PROJECT_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FIREBASE_PROJECT_ID"
        },
        {
          "name": "FIREBASE_CLIENT_EMAIL",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FIREBASE_CLIENT_EMAIL"
        },
        {
          "name": "FIREBASE_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FIREBASE_PRIVATE_KEY"
        },
        {
          "name": "FIREBASE_PRIVATE_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FIREBASE_PRIVATE_KEY_ID"
        },
        {
          "name": "FIREBASE_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/FIREBASE_CLIENT_ID"
        },
        {
          "name": "BACKEND_ADDRESS",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/BACKEND_ADDRESS"
        },
        {
          "name": "TWILIO_ACCOUNT_SID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/TWILIO_ACCOUNT_SID"
        },
        {
          "name": "TWILIO_AUTH_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/TWILIO_AUTH_TOKEN"
        },
        {
          "name": "TWILIO_PHONE_NUMBER",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:190275053744:secret:bonapka/TWILIO_PHONE_NUMBER"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bonapka-backend",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:5000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
