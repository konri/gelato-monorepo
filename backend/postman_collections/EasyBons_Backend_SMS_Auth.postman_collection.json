{
  "info": {
    "_postman_id": "backend-sms-auth-2024",
    "name": "EasyBons - Backend SMS Phone Auth",
    "description": "Backend SMS authentication endpoints - wysyłanie i weryfikacja kodów SMS z backendu",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "📱 Send SMS Code",
      "item": [
        {
          "name": "Send SMS Code - Valid Phone (ANY ROLE) - no params",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phoneNumber\": \"+48123456789\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/authorization/phone/send-code",
              "host": ["{{base_url}}"],
              "path": ["authorization", "phone", "send-code"]
            },
            "description": "Wysyła 6-cyfrowy kod weryfikacyjny SMS na podany numer telefonu. W trybie development kod jest logowany w konsoli backendu."
          },
          "response": []
        },
        {
          "name": "Send SMS Code - Missing Phone Number (Error)",
          "request": {
