    {
      "name": "🔄 Complete Flow Test",
      "item": [
        {
          "name": "Step 1: Send Code to New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phoneNumber\": \"+48111222333\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/authorization/phone/send-code",
              "host": ["{{base_url}}"],
              "path": ["authorization", "phone", "send-code"]
            },
            "description": "Krok 1: Wyślij kod SMS\n\nPo wysłaniu sprawdź konsole backendu:\n📱 SMS Code for +48111222333: 123456"
          },
          "response": []
        },
        {
          "name": "Step 2: Verify Code (New User Registration)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phoneNumber\": \"+48111222333\",\n    \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/authorization/phone/verify-code",
              "host": ["{{base_url}}"],
              "path": ["authorization", "phone", "verify-code"]
            },
            "description": "Krok 2: Zweryfikuj kod (użyj kodu z konsoli backendu)\n\nOczekiwany response:\n- isNewUser: true\n- token: JWT token\n- user: nowy użytkownik z rolą CLIENT"
          },
          "response": []
        },
        {
          "name": "Step 3: Send Code to Existing User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phoneNumber\": \"+48111222333\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/authorization/phone/send-code",
              "host": ["{{base_url}}"],
              "path": ["authorization", "phone", "send-code"]
            },
            "description": "Krok 3: Wyślij kod do istniejącego użytkownika (tego samego co w Step 1)\n\nUWAGA: Musisz poczekać 4 minuty od Step 1 (rate limiting)"
          },
          "response": []
        },
        {
          "name": "Step 4: Verify Code (Existing User Login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phoneNumber\": \"+48111222333\",\n    \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/authorization/phone/verify-code",
              "host": ["{{base_url}}"],
              "path": ["authorization", "phone", "verify-code"]
            },
            "description": "Krok 4: Zweryfikuj kod (użyj kodu z konsoli backendu)\n\nOczekiwany response:\n- isNewUser: false\n- token: JWT token\n- user: istniejący użytkownik"
          },
          "response": []
        }
      ],
      "description": "Pełny flow: wysłanie kodu → weryfikacja → rejestracja → ponowne logowanie"
    },
